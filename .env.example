# Discord Bot Token
TOKEN=YOUR_BOT_TOKEN_HERE

# Guild where ModMail threads are created
SUPPORT_GUILD_ID=YOUR_GUILD_ID

# Category where ModMail threads go
SUPPORT_CATEGORY_ID=YOUR_CATEGORY_ID

# Staff role allowed to use commands
STAFF_ROLE_ID=YOUR_STAFF_ROLE_ID

# Uptime server port (Render/Railway/Replit)
PORT=3000
